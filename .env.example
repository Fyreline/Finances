# Kakeibo — apps/server/.env template (docs/SECRETS.md is the full guide).
# Copy to apps/server/.env and fill in. NEVER commit the filled file.
# After edits in production: launchctl kickstart -k gui/$(id -u)/com.kakeibo.api

# --- Required to boot ---------------------------------------------------------
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
KAKEIBO_JWT_SECRET=

# --- Identity (AUTH.md) — defaults are fine on the household Mac --------------
#KAKEIBO_MISHKA_BASE_URL=http://127.0.0.1:8000

# --- Starling (API.md §1) — developer.starlingbank.com → Personal Access ------
# Create with READ-ONLY scopes only: account:read balance:read transaction:read
# savings-goal:read (API.md §1a — corrected in Phase 2 from an earlier guess
# of "space:read", which isn't a real Starling scope name).
KAKEIBO_STARLING_PAT=
# Optional: floor date (YYYY-MM-DD) for the first-ever backfill window, e.g.
# "2024-01-01". Leave unset to backfill from each account's own createdAt
# instead (API.md §1c) — deliberately not defaulted to any real date here;
# if a "relevant era" floor matters to you, set it locally (PRIVATE.md).
#KAKEIBO_STARLING_BACKFILL_START=

# --- Trading 212 (API.md §2) — app → Settings → API (Beta), read-only ---------
# Basic auth pair; the secret is shown once at creation.
KAKEIBO_T212_API_KEY=
KAKEIBO_T212_API_SECRET=
KAKEIBO_T212_ENV=live

# --- Goal seeding (DATA_MODEL.md §4, phases/PHASE-3-t212-goals.md item 4) -----
# NOT secrets — personal-finance values deliberately kept out of committed
# source/docs per PRIVATE.md's redaction scheme (this repo is public). Unset
# by default: the house_deposit / t212_rebuild goals simply aren't created
# until these are filled in locally; emergency_fund seeds regardless (its
# real target is derived in Phase 4, not configured here).
#KAKEIBO_GOAL_HOUSE_DEPOSIT_TARGET_MINOR=
#KAKEIBO_GOAL_HOUSE_DEPOSIT_TARGET_DATE=
#KAKEIBO_GOAL_HOUSE_DEPOSIT_BASELINE_MINOR=
#KAKEIBO_GOAL_HOUSE_DEPOSIT_BASELINE_DATE=
#KAKEIBO_GOAL_T212_REBUILD_BASELINE_MINOR=
#KAKEIBO_GOAL_T212_REBUILD_BASELINE_DATE=

# --- Sibling read for Sukumo (API.md §5, SECRETS.md) --------------------------
# Static bearer token for GET /api/goal/service. Generate: openssl rand -hex 24
# — the same value goes in Sukumo's .env as SUKUMO_KAKEIBO_SERVICE_TOKEN. Unset:
# the endpoint answers 503 and Sukumo's tile shows not-configured.
#KAKEIBO_SERVICE_TOKEN=

# --- Gmail, read-only (API.md §3) ---------------------------------------------
# Desktop-app OAuth client JSON from Google Cloud console (project kakeibo-local);
# token file is created by: .venv/bin/python scripts/gmail_authorise.py
KAKEIBO_GMAIL_CREDENTIALS_PATH=data/secrets/client_secret.json
KAKEIBO_GMAIL_TOKEN_PATH=data/secrets/gmail-token.json
# Known rental-paperwork senders (letting agent, lender, insurer, HMRC/accountant),
# comma-separated — the pull query is built from these (API.md §3c). Empty until
# HANDOFF Q3 is answered; while empty the pull no-ops with a not_configured row.
# Real addresses live only here in your local .env, never committed (PRIVATE.md).
#KAKEIBO_GMAIL_SENDERS=agent@example.com,noreply@lender.example
# Default widened to 1700 days (~4.6y, docs/phases/PHASE-13-rental-history-and-
# safe-to-spend-fix.md item A) — comfortably covers a multi-year tenancy/
# employment history without hardcoding a real start date; dedup on
# gmail_message_id makes a wide window harmless to re-run.
#KAKEIBO_GMAIL_SEARCH_DAYS=1700

# --- Infrastructure (defaults shown; dev uses port 8201 + kakeibo.dev.db) -----
#KAKEIBO_DATABASE_URL=sqlite:///data/kakeibo.db
#KAKEIBO_CORS_ORIGINS=["http://localhost:5178","http://127.0.0.1:5178","https://fyreline.github.io"]
#KAKEIBO_ACCESS_TOKEN_TTL_MINUTES=15
#KAKEIBO_REFRESH_TOKEN_TTL_DAYS=30
